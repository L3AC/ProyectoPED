<Window x:Class="ProyectoPED.Views.ReportesWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Title="Reportes y Estadísticas" 
             Height="600" Width="700"
             WindowStartupLocation="CenterOwner"
             ShowInTaskbar="False"
             ResizeMode="NoResize"
             Background="#F3F4F6">

    <Grid>
        <Border Background="White" CornerRadius="12" Margin="20">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="15" Opacity="0.15" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#10B981" CornerRadius="12,12,0,0" Padding="25,20">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ChartBar" Width="28" Height="28" Foreground="White" Margin="0,0,12,0"/>
                        <TextBlock Text="Reportes y Estadísticas" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Contenido -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20">
                    <StackPanel>
                        <!-- Resumen General -->
                        <TextBlock Text="Resumen General" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,0,0,15"/>
                        <UniformGrid Columns="3" Margin="0,0,0,20">
                            <Border Background="#DBEAFE" CornerRadius="8" Padding="20" Margin="0,0,10,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtTotalTareas" Text="0" FontSize="32" FontWeight="Bold" Foreground="#2563EB" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Total Tareas" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#D1FAE5" CornerRadius="8" Padding="20" Margin="5,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtCompletadas" Text="0" FontSize="32" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Completadas" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#FEE2E2" CornerRadius="8" Padding="20" Margin="10,0,0,0">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock x:Name="TxtVencidas" Text="0" FontSize="32" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Vencidas" FontSize="14" Foreground="#6B7280" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Tareas Vencidas -->
                        <TextBlock Text="Tareas Vencidas" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,10,0,15"/>
                        <Border Background="#FEF2F2" CornerRadius="8" Padding="15" MinHeight="100">
                            <DataGrid x:Name="DgTareasVencidas" AutoGenerateColumns="False" 
                                      CanUserAddRows="False" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal" HeadersVisibility="Column"
                                      BorderThickness="0" Background="Transparent">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Título" Binding="{Binding Titulo}" Width="*"/>
                                    <DataGridTextColumn Header="Fecha Límite" Binding="{Binding FechaLimite, StringFormat='{}{0:dd/MM/yyyy}'}" Width="120"/>
                                    <DataGridTextColumn Header="Días Vencida" Binding="{Binding DiasVencida}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- Estadísticas por Prioridad -->
                        <TextBlock Text="Por Prioridad" FontSize="16" FontWeight="SemiBold" Foreground="#1F2937" Margin="0,25,0,15"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <Border Background="#FEE2E2" CornerRadius="8" Padding="15" Width="100">
                                    <TextBlock x:Name="TxtPrioridadAlta" Text="0" FontSize="24" FontWeight="Bold" Foreground="#DC2626" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Alta" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#6B7280"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="15" Width="100">
                                    <TextBlock x:Name="TxtPrioridadMedia" Text="0" FontSize="24" FontWeight="Bold" Foreground="#D97706" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Media" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#6B7280"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <Border Background="#D1FAE5" CornerRadius="8" Padding="15" Width="100">
                                    <TextBlock x:Name="TxtPrioridadBaja" Text="0" FontSize="24" FontWeight="Bold" Foreground="#059669" HorizontalAlignment="Center"/>
                                </Border>
                                <TextBlock Text="Baja" HorizontalAlignment="Center" Margin="0,8,0,0" Foreground="#6B7280"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>

                <!-- Botón Cerrar -->
                <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="0,0,12,12" Padding="25,15">
                    <Button Content="Cerrar" Padding="30,10" HorizontalAlignment="Right"
                            Style="{StaticResource MaterialDesignRaisedButton}"
                            Background="#6B7280"
                            Click="BtnCerrar_Click"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
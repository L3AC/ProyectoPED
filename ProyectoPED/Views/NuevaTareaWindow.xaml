<Window x:Class="ProyectoPED.Views.NuevaTareaWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Title="Nueva Tarea Académica" 
             Height="620" Width="520"
             WindowStartupLocation="CenterOwner"
             ShowInTaskbar="False"
             ResizeMode="NoResize"
             Background="#F3F4F6">

    <Grid>
        <Border Background="White" CornerRadius="12" Margin="20">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="15" Opacity="0.15" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Background="#6366F1" CornerRadius="12,12,0,0" Padding="25,20">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="PlusCircle" Width="28" Height="28" Foreground="White" Margin="0,0,12,0"/>
                        <TextBlock Text="Nueva Tarea Académica" FontSize="20" FontWeight="SemiBold" Foreground="White"/>
                    </StackPanel>
                </Border>

                <!-- Formulario -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="25,20">
                    <StackPanel>
                        <!-- Título -->
                        <TextBlock Text="Título de la tarea" FontSize="13" FontWeight="Medium" Foreground="#374151" Margin="0,0,0,8"/>
                        <TextBox x:Name="TxtTitulo" Padding="12,10" FontSize="14"
                                 materialDesign:HintAssist.Hint="Ej: Proyecto Final de Base de Datos"
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <!-- Descripción -->
                        <TextBlock Text="Descripción" FontSize="13" FontWeight="Medium" Foreground="#374151" Margin="0,20,0,8"/>
                        <TextBox x:Name="TxtDescripcion" Padding="12,10" FontSize="14" Height="100"
                                 TextWrapping="Wrap" AcceptsReturn="True" VerticalContentAlignment="Top"
                                 materialDesign:HintAssist.Hint="Describe los detalles de la tarea..."
                                 Style="{StaticResource MaterialDesignOutlinedTextBox}"/>

                        <!-- Fecha Límite -->
                        <TextBlock Text="Fecha Límite" FontSize="13" FontWeight="Medium" Foreground="#374151" Margin="0,20,0,8"/>
                        <DatePicker x:Name="DpFechaLimite" Padding="12,10" FontSize="14"
                                    materialDesign:HintAssist.Hint="Seleccionar fecha"
                                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

                        <!-- Prioridad -->
                        <TextBlock Text="Prioridad" FontSize="13" FontWeight="Medium" Foreground="#374151" Margin="0,20,0,8"/>
                        <ComboBox x:Name="CmbPrioridad" Padding="12,10" FontSize="14"
                                  materialDesign:HintAssist.Hint="Seleccionar prioridad"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}">
                            <ComboBoxItem Content="Alta" IsSelected="True"/>
                            <ComboBoxItem Content="Media"/>
                            <ComboBoxItem Content="Baja"/>
                        </ComboBox>

                        <!-- Subtareas -->
                        <TextBlock Text="Subtareas" FontSize="13" FontWeight="Medium" Foreground="#374151" Margin="0,20,0,8"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="TxtSubtarea" Grid.Column="0" Padding="12,10" FontSize="14"
                                     materialDesign:HintAssist.Hint="Nueva subtarea"
                                     Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
                            <Button Grid.Column="1" Content="+" Margin="10,0,0,0" Width="40" Height="40"
                                    Style="{StaticResource MaterialDesignRaisedButton}"
                                    Click="BtnAgregarSubtarea_Click"/>
                        </Grid>
                        <ListBox x:Name="LbSubtareas" Margin="0,10,0,0" MaxHeight="100"/>

                        <!-- Dependencias -->
                        <TextBlock Text="Dependencias (tarea de la que depende)" FontSize="13" FontWeight="Medium" Foreground="#374151" Margin="0,20,0,8"/>
                        <ComboBox x:Name="CmbDependencias" Padding="12,10" FontSize="14"
                                  materialDesign:HintAssist.Hint="Seleccionar tarea (opcional)"
                                  Style="{StaticResource MaterialDesignOutlinedComboBox}"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Botones -->
                <Border Grid.Row="2" Background="#F9FAFB" CornerRadius="0,0,12,12" Padding="25,15">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Cancelar" Padding="20,10" Margin="0,0,10,0"
                                Style="{StaticResource MaterialDesignOutlinedButton}"
                                Click="BtnCancelar_Click"/>
                        <Button Content="Guardar Tarea" Padding="20,10"
                                Style="{StaticResource MaterialDesignRaisedButton}"
                                Background="#6366F1"
                                Click="BtnGuardar_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>
<UserControl x:Class="ProyectoPED.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <!-- Colores Profesionales -->
        <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryDarkBrush" Color="#1D4ED8"/>
        <SolidColorBrush x:Key="SecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#8B5CF6"/>
        <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
        <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BackgroundBrush" Color="#F1F5F9"/>
        <SolidColorBrush x:Key="SidebarBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="SidebarHoverBrush" Color="#334155"/>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#94A3B8"/>
        
        <!-- Gradientes -->
        <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0">
            <GradientStop Color="#1E293B" Offset="0"/>
            <GradientStop Color="#0F172A" Offset="1"/>
        </LinearGradientBrush>

        <!-- Estilo Botón Sidebar -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Margin="12,3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#475569"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo Botón Acción Principal -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.3" Color="#2563EB"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource PrimaryDarkBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo Botón Acción Secundario -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E2E8F0"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F8FAFC"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#CBD5E1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo Botón Accent -->
        <Style x:Key="AccentButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" 
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Estilo Botón Success -->
        <Style x:Key="SuccessButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#059669"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo Botón Warning -->
        <Style x:Key="WarningButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#D97706"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Estilo Tarjeta Stats -->
        <Style x:Key="StatCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{StaticResource BackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{StaticResource HeaderGradient}">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="3" BlurRadius="12" Opacity="0.2" Color="#000000"/>
            </Border.Effect>
            <DockPanel>
                <!-- Logo y Título -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center" Margin="25,0,0,0">
                    <Border Background="{StaticResource PrimaryBrush}" CornerRadius="8" Padding="10,6" Margin="0,0,15,0">
                        <TextBlock Text="T" FontSize="22" FontWeight="Bold" Foreground="White"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TaskUni" FontSize="22" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Gestión de Tareas Universitarias" FontSize="11" Foreground="#94A3B8"/>
                    </StackPanel>
                </StackPanel>

                <!-- Usuario -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,25,0">
                    <StackPanel Margin="0,0,15,0" VerticalAlignment="Center">
                        <TextBlock x:Name="TxtNombreUsuario" Text="Usuario" FontSize="14" 
                                   FontWeight="SemiBold" Foreground="White"/>
                        <TextBlock x:Name="TxtCarnet" Text="20210001" FontSize="12" Foreground="#94A3B8"/>
                    </StackPanel>
                    <Border Background="#334155" CornerRadius="20" Width="40" Height="40" VerticalAlignment="Center">
                        <TextBlock Text="U" FontSize="16" FontWeight="Bold" Foreground="White" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Button Content="Cerrar Sesión" Style="{StaticResource SecondaryButtonStyle}" 
                            Margin="20,0,0,0" Padding="15,8" Click="BtnCerrarSesion_Click"/>
                </StackPanel>

                <!-- Fecha -->
                <Border Background="#334155" CornerRadius="6" Padding="12,6" 
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📅" FontSize="14" Margin="0,0,8,0"/>
                        <TextBlock x:Name="TxtFechaActual" Text="Lunes, 13 de Abril 2026" 
                                   FontSize="13" Foreground="#CBD5E1"/>
                    </StackPanel>
                </Border>
            </DockPanel>
        </Border>

        <!-- Contenido Principal -->
        <Grid Grid.Row="1" Margin="25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="White" CornerRadius="16" Margin="0,0,20,0">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="4" BlurRadius="15" Opacity="0.08" Color="#000000"/>
                </Border.Effect>
                <StackPanel Margin="0,20,0,20">
                    <TextBlock Text="MENÚ" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" 
                               Margin="25,0,0,15"/>

                    <Button Content="📊  Dashboard" Style="{StaticResource SidebarButtonStyle}" 
                            Background="{StaticResource PrimaryBrush}" Foreground="White" x:Name="BtnDashboard"/>
                    
                    <Button Content="➕  Nueva Tarea" Style="{StaticResource SidebarButtonStyle}" 
                            Click="BtnNuevaTarea_Click" x:Name="BtnNuevaTarea"/>
                    
                    <Button Content="⏰  Simular Día" Style="{StaticResource SidebarButtonStyle}" 
                            Click="BtnSimular_Click" x:Name="BtnSimular"/>
                    
                    <Button Content="📈  Reportes" Style="{StaticResource SidebarButtonStyle}" 
                            Click="BtnReportes_Click" x:Name="BtnReportes"/>
                    
                    <Separator Background="#E2E8F0" Margin="25,25"/>
                    
                    <Button Content="⚙️  Configuración" Style="{StaticResource SidebarButtonStyle}"/>
                    
                    <Button Content="❓  Ayuda" Style="{StaticResource SidebarButtonStyle}"/>
                    
                    <Separator Background="#E2E8F0" Margin="25,25"/>
                    
                    <Button Content="🔴  Cerrar Sesión" Style="{StaticResource SidebarButtonStyle}" 
                            Foreground="#EF4444" Click="BtnCerrarSesion_Click" x:Name="BtnLogOut"/>
                </StackPanel>
            </Border>

            <!-- Área Central -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título y Acciones -->
                <DockPanel Grid.Row="0" Margin="0,0,0,20">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Text="Panel de Control" FontSize="28" FontWeight="Bold" 
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Administra tus tareas y actividades académicas" 
                                   FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,5,0,0"/>
                    </StackPanel>
                    
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="↩ Deshacer" Style="{StaticResource SecondaryButtonStyle}" 
                                Click="BtnDeshacer_Click" Margin="0,0,10,0"/>
                        <Button Content="📈 Ver Reportes" Style="{StaticResource SecondaryButtonStyle}" 
                                Click="BtnReportes_Click" Margin="0,0,10,0"/>
                        <Button Content="⏰ Simular 1 Día" Style="{StaticResource WarningButtonStyle}" 
                                Click="BtnSimular_Click"/>
                        <Button Content="➕ Nueva Tarea" Style="{StaticResource PrimaryButtonStyle}" 
                                Click="BtnNuevaTarea_Click" Margin="10,0,0,0"/>
                    </StackPanel>
                </DockPanel>

                <!-- Tarjetas de Estadísticas -->
                <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,20">
                    <!-- Tarjeta Pendientes -->
                    <Border Style="{StaticResource StatCardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <DockPanel>
                                <Border Background="#DBEAFE" CornerRadius="8" Padding="10" Width="44" Height="44">
                                    <TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="TxtPendientes" Text="12" DockPanel.Dock="Right" 
                                           HorizontalAlignment="Right" FontSize="32" FontWeight="Bold" 
                                           Foreground="{StaticResource PrimaryBrush}"/>
                            </DockPanel>
                            <TextBlock Text="Tareas Pendientes" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0"/>
                            <TextBlock Text="Pendientes esta semana" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Tarjeta Completadas -->
                    <Border Style="{StaticResource StatCardStyle}" Margin="6,0">
                        <StackPanel>
                            <DockPanel>
                                <Border Background="#D1FAE5" CornerRadius="8" Padding="10" Width="44" Height="44">
                                    <TextBlock Text="✅" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="TxtCompletadas" DockPanel.Dock="Right" 
                                           HorizontalAlignment="Right" FontSize="32" FontWeight="Bold" 
                                           Foreground="{StaticResource SuccessBrush}"/>
                            </DockPanel>
                            <TextBlock Text="Completadas" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0"/>
                            <TextBlock Text="Tareas finalizadas" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Tarjeta Vencidas -->
                    <Border Style="{StaticResource StatCardStyle}" Margin="6,0">
                        <StackPanel>
                            <DockPanel>
                                <Border Background="#FEE2E2" CornerRadius="8" Padding="10" Width="44" Height="44">
                                    <TextBlock Text="⚠️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="TxtVencidas" DockPanel.Dock="Right" 
                                           HorizontalAlignment="Right" FontSize="32" FontWeight="Bold" 
                                           Foreground="{StaticResource DangerBrush}"/>
                            </DockPanel>
                            <TextBlock Text="Vencidas" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0"/>
                            <TextBlock Text="Sin completar a tiempo" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Tarjeta Progress -->
                    <Border Style="{StaticResource StatCardStyle}" Margin="12,0,0,0">
                        <StackPanel>
                            <DockPanel>
                                <Border Background="#FEF3C7" CornerRadius="8" Padding="10" Width="44" Height="44">
                                    <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <TextBlock x:Name="TxtProgreso" Text="78%" DockPanel.Dock="Right" 
                                           HorizontalAlignment="Right" FontSize="32" FontWeight="Bold" 
                                           Foreground="{StaticResource WarningBrush}"/>
                            </DockPanel>
                            <TextBlock Text="Progreso" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,12,0,0"/>
                            <TextBlock Text="Tasa de completación" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- DataGrid de Tareas -->
                <Border Grid.Row="2" Background="White" CornerRadius="16">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="4" BlurRadius="15" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Header del DataGrid -->
                        <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="16,16,0,0" Padding="20,15">
                            <DockPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📋" FontSize="18" Margin="0,0,10,0"/>
                                    <TextBlock Text="Lista de Tareas" FontSize="16" FontWeight="SemiBold" 
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <TextBlock Text="Mostrando todas las tareas" DockPanel.Dock="Right" 
                                           HorizontalAlignment="Right" FontSize="13" Foreground="{StaticResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </Border>

                        <DataGrid x:Name="DgTareas" Grid.Row="1" AutoGenerateColumns="False" 
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column" RowHeaderWidth="0"
                                  BorderThickness="0" Background="White"
                                  SelectionMode="Single" SelectionUnit="FullRow"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  RowHeight="52">
                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Foreground" Value="#64748B"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="FontSize" Value="13"/>
                                    <Setter Property="Padding" Value="16,14"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="White"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#EFF6FF"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#F8FAFC"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Padding" Value="16,0"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridCell">
                                                <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>
                            
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                            <Setter Property="Foreground" Value="#64748B"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Título de la Tarea" Binding="{Binding Titulo}" Width="*">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Medium"/>
                                            <Setter Property="Foreground" Value="#1E293B"/>
                                            <Setter Property="FontSize" Value="14"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTextColumn Header="Fecha Límite" Binding="{Binding FechaLimite, StringFormat='{}{0:dd MMM yyyy}'}" Width="130">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#64748B"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>
                                
                                <DataGridTemplateColumn Header="Días Restantes" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="12,6" HorizontalAlignment="Left"
                                                    Background="{Binding ColorDiasRestantes}">
                                                <TextBlock Text="{Binding DiasRestantesTexto}" 
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn Header="Prioridad" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="12,6" HorizontalAlignment="Left"
                                                    Background="{Binding ColorPrioridad}">
                                                <TextBlock Text="{Binding Prioridad}" 
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn Header="Estado" Width="120">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="6" Padding="12,6" HorizontalAlignment="Left"
                                                    Background="{Binding ColorEstado}">
                                                <TextBlock Text="{Binding Estado}" 
                                                           FontWeight="SemiBold" FontSize="12"
                                                           Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                
                                <DataGridTemplateColumn Header="Acciones" Width="200">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="✓ Completar" 
                                                        Style="{StaticResource SuccessButtonStyle}"
                                                        Click="BtnCompletar_Click" Tag="{Binding Id}"
                                                        Visibility="{Binding MostrarCompletar, Converter={StaticResource BoolToVisibility}}"
                                                        Margin="0,0,8,0"/>
                                                <Button Content="✎ Editar" 
                                                        Style="{StaticResource AccentButtonStyle}"
                                                        Click="BtnEditar_Click" Tag="{Binding Id}"
                                                        Background="#64748B"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <!-- Leyenda -->
                <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="20" Margin="0,20,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.06" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Leyenda de Días Restantes:" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <Border Background="#10B981" CornerRadius="6" Padding="12,6" Margin="0,0,10,0">
                            <TextBlock Text="Verde (>7 días)" Foreground="White" FontSize="12"/>
                        </Border>
                        <Border Background="#F59E0B" CornerRadius="6" Padding="12,6" Margin="0,0,10,0">
                            <TextBlock Text="Amarillo (4-7 días)" Foreground="White" FontSize="12"/>
                        </Border>
                        <Border Background="#F97316" CornerRadius="6" Padding="12,6" Margin="0,0,10,0">
                            <TextBlock Text="Naranja (1-3 días)" Foreground="White" FontSize="12"/>
                        </Border>
                        <Border Background="#EF4444" CornerRadius="6" Padding="12,6">
                            <TextBlock Text="Rojo (Vencida)" Foreground="White" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
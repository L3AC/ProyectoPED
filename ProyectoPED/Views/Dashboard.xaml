<UserControl x:Class="ProyectoPED.Views.Dashboard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1200">

    <UserControl.Resources>
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#A5B4FC"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="8" Margin="12,3">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" 
                                              VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#3D3D6B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="Active">
                                <Setter TargetName="border" Property="Background" Value="#4D4D8B"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#8B5CF6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#7C3AED"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="#6366F1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#4F46E5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="EditButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UndoButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#9CA3AF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#6B7280"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#22C55E"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#16A34A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#E5E7EB"/>
            <Setter Property="Foreground" Value="#374151"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,4"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D1D5DB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. Barra Superior (Header) -->
        <Border Grid.Row="0" Background="{StaticResource HeaderBackgroundBrush}">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="8" Opacity="0.2" Color="#000000"/>
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo TaskUni -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="25,0,0,0">
                    <Image Source="/logo.png" Width="42" Height="42" Margin="0,0,14,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TaskUni" FontSize="19" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Gestión Académica" FontSize="10" Foreground="#A5B4FC" Margin="0,-2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bienvenida y Carné (Centrado) -->
                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="AccountCircle" Foreground="#A5B4FC" Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtNombreUsuario" Text="Bienvenido/a María López" 
                                   FontSize="15" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <materialDesign:PackIcon Kind="CardAccountDetails" Foreground="#818CF8" Width="14" Height="14" Margin="0,0,6,0"/>
                        <TextBlock x:Name="TxtCarnet" Text="Carné: 2023-00123" 
                                   FontSize="12" Foreground="#A5B4FC"/>
                    </StackPanel>
                </StackPanel>

                <!-- Botón Cerrar Sesión -->
                <Button Grid.Column="2" Content="Cerrar sesión" 
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,25,0" Padding="12,4" Height="28" VerticalAlignment="Center"
                        Click="BtnCerrarSesion_Click"/>
            </Grid>
        </Border>

        <!-- Contenido Principal -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="AVLColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <!-- 2. Sidebar Izquierdo -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,20,0,0">
                        <Button Content="📊  Dashboard" Style="{StaticResource SidebarButtonStyle}" 
                                Tag="Active" x:Name="BtnDashboard"/>
                        
                        <Button Content="➕  Nueva tarea" Style="{StaticResource SidebarButtonStyle}" 
                                Click="BtnNuevaTarea_Click" x:Name="BtnNuevaTarea"
                                Background="#6366F1" Foreground="White" Margin="12,8,12,12" Padding="20,14"/>
                        
                        <Button Content="⏰  Simular 1 día" Style="{StaticResource SidebarButtonStyle}" 
                                Click="BtnSimular_Click" x:Name="BtnSimular"/>
                        
                        <Button Content="🌳  Ver estructura AVL" Style="{StaticResource SidebarButtonStyle}" 
                                Click="BtnVerAVL_Click" x:Name="BtnVerAVL"/>
                        
                        <Button Content="📈  Reportes" Style="{StaticResource SidebarButtonStyle}" 
                                Click="BtnReportes_Click" x:Name="BtnReportes"/>
                    </StackPanel>

                    <!-- Sección inferior del sidebar -->
                    <StackPanel Grid.Row="1" Margin="20,0,20,20">
                        <Separator Background="#3D3D6B" Margin="0,0,0,15"/>
                        <Button Content="↩  Deshacer acción" Style="{StaticResource SidebarButtonStyle}" 
                                Click="BtnDeshacer_Click" x:Name="BtnDeshacer"/>
                        <StackPanel Orientation="Horizontal" Margin="12,8,0,0">
                            <materialDesign:PackIcon Kind="StackExchange" Foreground="#A5B4FC" Width="16" Height="16" Margin="0,0,8,0"/>
                            <TextBlock Text="Pila" FontSize="12" Foreground="#A5B4FC"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 3. Área Central (Panel de Tareas) -->
            <Grid Grid.Column="1" Margin="25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Título y Fecha -->
                <StackPanel Grid.Row="0" Margin="0,0,0,20">
                    <TextBlock Text="Panel de Tareas" FontSize="28" FontWeight="Bold" 
                               Foreground="#1F2937"/>
                    <TextBlock x:Name="TxtFechaActual" Text="00 / 00 / 0000" 
                               FontSize="14" Foreground="#6B7280" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- DataGrid de Tareas -->
                <Border Grid.Row="1" Background="White" CornerRadius="12">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.08" Color="#000000"/>
                    </Border.Effect>
                    <DataGrid x:Name="DgTareas" AutoGenerateColumns="False" 
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              IsReadOnly="True" GridLinesVisibility="None"
                              HeadersVisibility="Column" RowHeaderWidth="0"
                              BorderThickness="0" Background="Transparent"
                              SelectionMode="Single" SelectionUnit="FullRow"
                              HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Auto"
                              RowHeight="54"
                              MinRowHeight="54"
                              EnableColumnVirtualization="True"
                              EnableRowVirtualization="True"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F9FAFB"/>
                                <Setter Property="Foreground" Value="#6B7280"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="13"/>
                                <Setter Property="Padding" Value="16,14"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="#E5E7EB"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#EEF2FF"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F9FAFB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.CellStyle>
                            <Style TargetType="DataGridCell">
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Padding="{TemplateBinding Padding}" Background="{TemplateBinding Background}">
                                                <ContentPresenter VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.CellStyle>
                        
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                        <Setter Property="Foreground" Value="#6B7280"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTextColumn Header="Título" Binding="{Binding Titulo}" Width="2*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="Medium"/>
                                        <Setter Property="Foreground" Value="#1F2937"/>
                                        <Setter Property="FontSize" Value="14"/>
                                        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <DataGridTextColumn Header="Fecha límite" Binding="{Binding FechaLimite, StringFormat='{}{0:dd/MM/yyyy}'}" Width="100">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="#6B7280"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            
                            <!-- Días restantes con colores condicionales -->
                            <DataGridTemplateColumn Header="Días rest." Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="8,4" HorizontalAlignment="Center"
                                                Background="{Binding ColorDiasRestantes}">
                                            <TextBlock Text="{Binding DiasRestantesTexto}" 
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Prioridad con colores condicionales -->
                            <DataGridTemplateColumn Header="Prioridad" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="8,4" HorizontalAlignment="Center"
                                                Background="{Binding ColorPrioridad}">
                                            <TextBlock Text="{Binding Prioridad}" 
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="{Binding ColorTextoPrioridad}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Estado -->
                            <DataGridTemplateColumn Header="Estado" Width="100">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="6" Padding="8,4" HorizontalAlignment="Center"
                                                Background="{Binding ColorEstado}">
                                            <TextBlock Text="{Binding Estado}" 
                                                       FontWeight="SemiBold" FontSize="11"
                                                       Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Acciones con botones condicionales según Estado -->
                            <DataGridTemplateColumn Header="Acciones" Width="240">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <!-- Botones para estado Pendiente -->
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Estado}" Value="Completada">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <Button Style="{StaticResource SuccessButtonStyle}"
                                                        Click="BtnCompletar_Click" Tag="{Binding Id}"
                                                        Margin="0,0,8,0" MinWidth="90">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Check" Width="14" Height="14" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Completar"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Style="{StaticResource EditButtonStyle}"
                                                        Click="BtnEditar_Click" Tag="{Binding Id}"
                                                        MinWidth="80">
                                                    <StackPanel Orientation="Horizontal">
                                                        <materialDesign:PackIcon Kind="Pencil" Width="14" Height="14" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Editar"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                            <!-- Botón Deshacer para estado Completada -->
                                            <Button Click="BtnDeshacer_Click" Tag="{Binding Id}"
                                                    HorizontalAlignment="Center" MinWidth="90">
                                                <Button.Style>
                                                    <Style TargetType="Button" BasedOn="{StaticResource UndoButtonStyle}">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Estado}" Value="Completada">
                                                                <Setter Property="Visibility" Value="Visible"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <materialDesign:PackIcon Kind="Undo" Width="14" Height="14" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Deshacer"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Leyenda de Colores -->
                <Border Grid.Row="2" Background="White" CornerRadius="10" Padding="20" Margin="0,20,0,0">
                    <Border.Effect>
                        <DropShadowEffect ShadowDepth="1" BlurRadius="6" Opacity="0.05" Color="#000000"/>
                    </Border.Effect>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Días restantes:" FontWeight="SemiBold" 
                                   Foreground="#374151" VerticalAlignment="Center" Margin="0,0,15,0"/>
                        <Border Background="#22C55E" CornerRadius="4" Padding="10,5" Margin="0,0,8,0">
                            <TextBlock Text="Verde (8+)" Foreground="White" FontSize="11"/>
                        </Border>
                        <Border Background="#F97316" CornerRadius="4" Padding="10,5" Margin="0,0,8,0">
                            <TextBlock Text="Naranja (4-7)" Foreground="White" FontSize="11"/>
                        </Border>
                        <Border Background="#EF4444" CornerRadius="4" Padding="10,5">
                            <TextBlock Text="Rojo (≤3)" Foreground="White" FontSize="11"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 4. Panel Derecho (Estructura AVL) -->
            <Border Grid.Column="2" x:Name="AVLPanel" Background="White" Visibility="Collapsed">
                <Border.Effect>
                    <DropShadowEffect ShadowDepth="-3" BlurRadius="15" Opacity="0.15" Color="#000000"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header del Panel AVL -->
                    <Border Grid.Row="0" Background="#F9FAFB" CornerRadius="12,12,0,0" Padding="20">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="✕" 
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Click="BtnCerrarAVL_Click" Padding="10,6"/>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="Tree" Width="24" Height="24" Foreground="#6366F1" Margin="0,0,10,0"/>
                                <TextBlock Text="Estructura del Árbol AVL" FontSize="18" FontWeight="SemiBold" 
                                           Foreground="#1F2937" VerticalAlignment="Center"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Área del Árbol AVL (Placeholder) -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <Canvas x:Name="AVLCanvas" Width="400" Height="400" Background="#FAFAFA">
                            <!-- Aquí se dibujarán los nodos del árbol AVL dinámicamente -->
                        </Canvas>
                    </ScrollViewer>

                    <!-- Botones del Panel AVL -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20">
                        <Button Content="🔄  Actualizar árbol" Style="{StaticResource PrimaryButtonStyle}" 
                                Click="BtnActualizarAVL_Click" Margin="0,0,10,0"/>
                        <Button Content="✕  Cerrar panel" Style="{StaticResource SecondaryButtonStyle}" 
                                Click="BtnCerrarAVL_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
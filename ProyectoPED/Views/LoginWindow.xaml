<Window x:Class="ProyectoPED.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="TaskUni - Iniciar sesión" Height="550" Width="450"
        WindowStartupLocation="CenterScreen"
        Background="#F4F4F5"
        ResizeMode="NoResize"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Estilo base para cajas de texto -->
        <Style x:Key="RoundedTextBox" TargetType="TextBox" BasedOn="{StaticResource MaterialDesignTextBox}">
            <Setter Property="Background" Value="#F1EFEB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="8"/>
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="Transparent"/>
            <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="False"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#9CA3AF"/>
        </Style>

        <Style x:Key="RoundedPasswordBox" TargetType="PasswordBox" BasedOn="{StaticResource MaterialDesignPasswordBox}">
            <Setter Property="Background" Value="#F1EFEB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="materialDesign:TextFieldAssist.TextFieldCornerRadius" Value="8"/>
            <Setter Property="materialDesign:TextFieldAssist.UnderlineBrush" Value="Transparent"/>
            <Setter Property="materialDesign:TextFieldAssist.HasClearButton" Value="False"/>
            <Setter Property="materialDesign:HintAssist.Foreground" Value="#9CA3AF"/>
        </Style>

        <!-- Estilo para botones primarios -->
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource MaterialDesignRaisedButton}">
            <Setter Property="Background" Value="#5B51C8"/>
            <Setter Property="BorderBrush" Value="#5B51C8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="materialDesign:ButtonAssist.CornerRadius" Value="8"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <!-- Panel de Iniciar Sesión -->
        <Border x:Name="LoginPanel" Background="White" CornerRadius="16" Padding="30"
                BorderBrush="#E5E7EB" BorderThickness="1"
                VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Iniciar sesión" FontSize="22" FontWeight="SemiBold" Foreground="#374151" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <Separator Background="#F3F4F6" Margin="0,0,0,20"/>

                <TextBlock Text="Carné" Foreground="#6B7280" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCarneLogin" Style="{StaticResource RoundedTextBox}" 
                         materialDesign:HintAssist.Hint="Ej. 2023-12345" Margin="0,0,0,15"/>

                <TextBlock Text="Contraseña" Foreground="#6B7280" FontSize="13" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPasswordLogin" Style="{StaticResource RoundedPasswordBox}" 
                             materialDesign:HintAssist.Hint="••••••••" Margin="0,0,0,25"/>

                <Button Content="Iniciar sesión" Style="{StaticResource PrimaryButton}" 
                        Click="BtnLogin_Click" Margin="0,0,0,20"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
                    <TextBlock Text="¿No tienes cuenta? " Foreground="#6B7280" FontSize="13"/>
                    <Button Content="Registrarse" Style="{StaticResource MaterialDesignFlatButton}" 
                            Foreground="#5B51C8" FontSize="13" Padding="0" Height="Auto" 
                            Click="BtnIrRegistro_Click" Cursor="Hand"/>
                </StackPanel>

                <Border x:Name="ErrorPanel" Background="#FEE2E2" BorderBrush="#FCA5A5" BorderThickness="1" CornerRadius="8" Padding="10" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="Carné o contraseña incorrectos" Foreground="#B91C1C" FontWeight="SemiBold" FontSize="13" HorizontalAlignment="Center"/>
                        <TextBlock Text="(solo visible si hay error)" Foreground="#EF4444" FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- Panel de Registro -->
        <Border x:Name="RegisterPanel" Background="White" CornerRadius="16" Padding="30"
                BorderBrush="#E5E7EB" BorderThickness="1"
                VerticalAlignment="Center" Visibility="Collapsed">
            <Border.Effect>
                <DropShadowEffect Color="#000000" Opacity="0.05" BlurRadius="15" ShadowDepth="2"/>
            </Border.Effect>
            <StackPanel>
                <TextBlock Text="Crear nueva cuenta" FontSize="22" FontWeight="SemiBold" Foreground="#374151" HorizontalAlignment="Center" Margin="0,0,0,15"/>
                <Separator Background="#F3F4F6" Margin="0,0,0,20"/>

                <TextBlock Text="Carné" Foreground="#6B7280" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="txtCarneReg" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Nombre completo" Foreground="#6B7280" FontSize="13" Margin="0,0,0,5"/>
                <TextBox x:Name="txtNombreReg" Style="{StaticResource RoundedTextBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Contraseña" Foreground="#6B7280" FontSize="13" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPasswordReg" Style="{StaticResource RoundedPasswordBox}" Margin="0,0,0,12"/>

                <TextBlock Text="Confirmar contraseña" Foreground="#6B7280" FontSize="13" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtConfirmPasswordReg" Style="{StaticResource RoundedPasswordBox}" Margin="0,0,0,25"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Button Grid.Column="0" Content="Crear cuenta" Style="{StaticResource PrimaryButton}" 
                            Click="BtnRegistrar_Click"/>
                    
                    <Button Grid.Column="2" Content="Cancelar" 
                            Background="White" BorderBrush="#D1D5DB" BorderThickness="1" Foreground="#4B5563"
                            materialDesign:ButtonAssist.CornerRadius="8" Height="42" FontWeight="SemiBold" FontSize="14"
                            Click="BtnCancelarRegistro_Click"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
